# OCR Worker Configuration

# API Base URL - should point to your Next.js API
PROCESSING_API_BASE=http://localhost:3000/api

# Worker Token - must match PROCESSING_WORKER_TOKEN in root .env.local
PROCESSING_WORKER_TOKEN=dev-worker-token

# Polling interval in seconds
PROCESSING_POLL_INTERVAL=5

# Tesseract OCR Path
# Windows (example):
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# macOS (Homebrew):
# TESSERACT_CMD=/usr/local/bin/tesseract

# Linux (apt):
# TESSERACT_CMD=/usr/bin/tesseract

# If tesseract is in your PATH, you can comment out TESSERACT_CMD
